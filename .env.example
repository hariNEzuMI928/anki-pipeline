# Anki syncing
ANKI_BASE=~/Library/Application Support/Anki2
ANKI_PROFILE=同期用

# Slack
SLACK_WEBHOOK_URL=

# Google Sheets (for density tracking)
SPREADSHEET_ID=
GOOGLE_CREDENTIALS_PATH=credentials.json

# Gemini (for GTrans processing)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Google Translate (Playwright scraping)
GOOGLE_TRANSLATE_FAVORITES_URL=https://translate.google.com/saved
PLAYWRIGHT_HEADLESS=true

# Pipeline control
BATCH_LIMIT=50
