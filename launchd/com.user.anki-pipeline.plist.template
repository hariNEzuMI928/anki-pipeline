<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.user.anki-pipeline</string>
    <key>ProcessType</key>
    <string>Background</string>
    <key>Nice</key>
    <integer>20</integer>
    <key>LowPriorityIO</key>
    <true/>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/mise</string>
        <string>run</string>
        <string>run-all</string>
    </array>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>{{HOME}}/.local/share/mise/shims:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>
    <key>WorkingDirectory</key>
    <string>{{HOME}}/Dev/anki-pipeline</string>
    <key>StandardOutPath</key>
    <string>{{HOME}}/Dev/anki-pipeline/logs/launchd_stdout.log</string>
    <key>StandardErrorPath</key>
    <string>{{HOME}}/Dev/anki-pipeline/logs/launchd_stderr.log</string>
    <key>StartCalendarInterval</key>
    <array>
        <dict>
            <key>Hour</key>
            <integer>3</integer>
            <key>Minute</key>
            <integer>0</integer>
        </dict>
    </array>
</dict>
</plist>
